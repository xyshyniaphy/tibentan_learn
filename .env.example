ANTHROPIC_AUTH_TOKEN=your_token_here
ANTHROPIC_BASE_URL=https://api.z.ai/api/anthropic

# IP whitelist for /input page and delete functionality (comma-separated)
# Supports IPv4 and IPv6 addresses
# For Docker: add the gateway IP (e.g., 172.17.0.1) or use X-Forwarded-For header
IP_WHITELIST=127.0.0.1,::1
